{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kui-realtime",
  "main": "src/index.js",
  "compatibility_date": "2026-07-12",
  "workers_dev": true,
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "kpanel",
      "database_id": "e29d1eba-2768-4ec9-a07e-11083edae7a6"
    }
  ],
  "durable_objects": {
    "bindings": [
      { "name": "VPS_PRESENCE", "class_name": "VpsPresence" },
      { "name": "DASHBOARD_HUB", "class_name": "DashboardHub" }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["VpsPresence", "DashboardHub"]
    }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 0.1
  }
}
